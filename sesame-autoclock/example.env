# Telegram (create the bot with @BotFather; leave CHAT_ID empty on first run,
# message the bot and it will reply with your chat id)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=

# Microsoft SSO account used by Sesame
SESAME_EMAIL=you@yourcompany.com
# Optional: if unset the bot will ask for it over Telegram when Microsoft requires it
SESAME_PASSWORD=

# Schedule (local time, see TZ). Each event gets +/- JITTER_MINUTES randomization.
# PLAN_TIME must be at or before OFFICE_REMIND_CLOCK_IN, or office-day
# reminders will fire late (they run immediately when planned after the fact).
PLAN_TIME=07:00
CLOCK_IN=09:00
BREAK_START=13:30
BREAK_MINUTES=45
WORK_MINUTES=480
JITTER_MINUTES=5

# Office days (Thursdays, REMOTE_WORK_WEEKDAYS in app/sesame.py): the bot
# cannot clock (Normal is IP-blocked outside the office network) and only
# sends reminders. In/back reminders repeat twice every
# OFFICE_REMIND_REPEAT_MINUTES while you haven't clocked; the clock-out
# reminder fires once the planned hours are worked (based on real signings).
OFFICE_REMIND_CLOCK_IN=07:30
OFFICE_REMIND_BREAK_START=12:50
OFFICE_REMIND_BREAK_END=14:00
OFFICE_REMIND_REPEAT_MINUTES=15

TZ=Europe/Madrid
HEADLESS=true
